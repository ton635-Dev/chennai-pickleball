# Supabase 接続情報(Supabase ダッシュボード > Project Settings > API から取得)
# この内容を .env.local にコピーして値を埋めてください。
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# アプリの公開URL(WhatsApp告知テキストの出欠登録リンクに使用)
# ローカルでは http://localhost:3000 のままでOK。Vercel公開時は本番URLに変更。
NEXT_PUBLIC_APP_URL=http://localhost:3000
